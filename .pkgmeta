# LibCodex-1.0 packaging manifest.
# Consumed by BigWigsMods/packager v2 (see .github/workflows/release.yml).
# Reference: https://github.com/BigWigsMods/packager

# Folder name inside the published zip. Must match the .toc filename so WoW
# can load the addon under the same name on user installs.
package-as: LibCodex-1.0

# Don't ship dev/build infrastructure to end users.
#  - .dev/         All dev-local artifacts: import dumps, caches, bake configs,
#                  downloaded SQL, Wowhead HTML. One folder, one ignore line.
#  - tools/        Python build tools (import-wago, crawl-wowhead, bake, diff)
#  - tests/        any local test scaffolding
#  - SESSION_NOTES.md is project-internal, not user-facing
#  - editor/IDE folders never ship
ignore:
  - .dev
  - tests
  - .vscode
  - .idea
  - SESSION_NOTES.md
  - "*.bat"
  - "*.py"
  - "*.ps1"

# We do NOT use @project-version@ substitution in the .toc -- the version
# field carries our YYMMDDHHMM build stamp and is bumped manually on every
# edit. The packager will leave a hardcoded `## Version:` line untouched, so
# no `enable-toc-creation` or `move-out-of-package-as` directives are needed.

# License is MIT; ship it inside the package so embedders see it.
# (LICENSE is at the repo root and lives inside package-as by default.)
