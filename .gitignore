# LibCodex-1.0 .gitignore
#
# All dev-local artifacts (import dumps, caches, bake configs, downloaded
# SQL, Wowhead HTML, etc.) live under /.dev/ at the repo root. One folder,
# one ignore line. Add new tooling artifacts there and you don't have to
# touch this file.
.dev/

# bake.py writes timestamped backups of each Data/*.lua before overwriting.
# These accumulate quickly across the per-flavor Data folders; never commit.
**/.bake-backup/

# Editor / IDE
.vscode/
.idea/
.cursor/
.claude/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Python build artifacts (mostly tools/__pycache__)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Misc backups
*.bak
*.orig
*.tmp
